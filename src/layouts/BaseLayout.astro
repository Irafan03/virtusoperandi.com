---
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import NewsletterSignup from '@components/NewsletterSignup.astro';
import { LANG_META, LANGS, langPath, SITE_URL } from '@i18n/config';
import { useTranslations } from '@i18n/translations';
import type { Lang } from '@i18n/config';

export interface Props {
  title:       string;
  description: string;
  canonical:   string;
  lang?:       Lang;
  langUrls?:   Partial<Record<Lang, string>>;
}

const { title, description, canonical, lang = 'fr', langUrls } = Astro.props;
const { dir } = LANG_META[lang];
const t = useTranslations(lang);
const currentPath = new URL(canonical).pathname;
---
<!doctype html>
<html lang={lang} dir={dir}>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<!-- hreflang alternates -->
{LANGS.map((l) => (
  <link rel="alternate" hreflang={l} href={`${SITE_URL}${langPath(l, currentPath.replace(/^\/(fr|en|ar)/, '') || '/')}`} />
))}
<link rel="alternate" hreflang="x-default" href={`${SITE_URL}${langPath('fr', currentPath.replace(/^\/(fr|en|ar)/, '') || '/')}`} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Open+Sans:wght@300;400;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/assets/site.css" />
<slot name="head" />
<!-- Crisp chat widget -->
<script type="text/javascript" define:vars={{ crispLang: lang, crispHide: /\/pricing(\/|$)/.test(new URL(canonical).pathname) }}>
  window.$crisp = [];
  window.CRISP_WEBSITE_ID = "3593d11a-1c26-4331-b78c-05a8238999ad";
  window.$crisp.push(["set", "session:locale", [crispLang]]);
  if (crispHide) window.$crisp.push(["do", "chat:hide"]);
  (function () {
    var s = document.createElement("script");
    s.src = "https://client.crisp.chat/l.js";
    s.async = true;
    document.head.appendChild(s);
  })();
</script>
</head>
<body>
<a class="skip" href="#main">{t.skipToContent}</a>

<div class="meta">
  <div class="meta-inner">
    <slot name="meta-label"><span class="meta-left"><span class="meta-dot" aria-hidden="true"></span>Virtus Operandi</span></slot>
  </div>
</div>

<header class="nav" id="nav">
  <div class="nav-inner">
    <a href={langPath(lang, '/')} class="brand" aria-label="Virtus Operandi home">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-word">Virtus <span class="lo">Operandi</span></span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a class="nav-link" href={langPath(lang, '/#products')}>{t.nav.products}</a>
      <a class="nav-link" href={langPath(lang, '/#industries')}>{t.nav.industries}</a>
      <a class="nav-link" href={langPath(lang, '/solutions')}>{t.nav.solutions}</a>
      <a class="nav-link" href={langPath(lang, '/pricing')}>{t.nav.pricing}</a>
      <a class="nav-link" href={langPath(lang, '/about')}>{t.nav.company}</a>
      <a class="nav-link" href={langPath(lang, '/insights')}>{t.nav.insights}</a>
      <a class="nav-link" href={langPath(lang, '/blog')}>{t.nav.blog}</a>
      <a class="nav-link" href={langPath(lang, '/contact')}>{t.nav.contact}</a>
      <a class="nav-cta"  href={langPath(lang, '/contact')}>{t.nav.cta}</a>
      <LanguageSwitcher currentLang={lang} currentPath={currentPath} langUrls={langUrls} />
    </nav>
    <button class="hamburger" id="ham" aria-label="Open menu" aria-expanded="false">
      <span class="bars" aria-hidden="true"></span>
    </button>
  </div>
</header>

<nav class="mobile-menu" id="mobile-menu" aria-label="Mobile" aria-hidden="true">
  <a href={langPath(lang, '/#products')}>{t.nav.products}</a>
  <a href={langPath(lang, '/#industries')}>{t.nav.industries}</a>
  <a href={langPath(lang, '/solutions')}>{t.nav.solutions}</a>
  <a href={langPath(lang, '/pricing')}>{t.nav.pricing}</a>
  <a href={langPath(lang, '/about')}>{t.nav.company}</a>
  <a href={langPath(lang, '/insights')}>{t.nav.insights}</a>
  <a href={langPath(lang, '/blog')}>{t.nav.blog}</a>
  <a href={langPath(lang, '/contact')}>{t.nav.contact}</a>
  <a href={langPath(lang, '/contact')} class="mob-cta">{t.nav.cta}</a>
  <LanguageSwitcher currentLang={lang} currentPath={currentPath} langUrls={langUrls} />
</nav>

<slot />

<footer>
  <div class="foot-inner">
    <div class="foot-top">
      <div class="brand-col">
        <a href={langPath(lang, '/')} class="brand">
          <span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-word">Virtus <span class="lo">Operandi</span></span>
        </a>
        <p>{t.footer.tagline}</p>
      </div>
      <div class="foot-col">
        <h4>{t.footer.products}</h4>
        <a href={langPath(lang, '/products/virtus-lever')}>Virtus Lever</a>
        <a href={langPath(lang, '/products/virtus-fleet')}>Virtus Fleet</a>
        <a href={langPath(lang, '/products/virtus-ai-factory')}>Virtus AI Factory</a>
        <a href={langPath(lang, '/products/virtus-agents')}>Virtus Agents</a>
        <a href={langPath(lang, '/products/virtus-ged')}>Virtus GED</a>
        <a href={langPath(lang, '/products/virtus-erp')}>Virtus ERP</a>
      </div>
      <div class="foot-col">
        <h4>{t.footer.industries}</h4>
        <a href={langPath(lang, '/industries/manufacturing')}>{t.industries.manufacturing}</a>
        <a href={langPath(lang, '/industries/transport-logistics')}>{t.industries.transport}</a>
        <a href={langPath(lang, '/industries/professional-services')}>{t.industries.professional}</a>
        <a href={langPath(lang, '/industries/cross-industry')}>{t.industries.crossIndustry}</a>
      </div>
      <div class="foot-col">
        <h4>{t.footer.company}</h4>
        <a href={langPath(lang, '/about')}>{t.footer.about}</a>
        <a href={langPath(lang, '/team')}>{t.footer.team}</a>
        <a href={langPath(lang, '/careers')}>{t.footer.careers}</a>
        <a href={langPath(lang, '/partners')}>{t.footer.partners}</a>
        <a href={langPath(lang, '/contact')}>{t.nav.contact}</a>
        <a href={langPath(lang, '/security')}>{t.footer.security}</a>
      </div>
      <div class="foot-col">
        <h4>{t.footer.legal}</h4>
        <a href={langPath(lang, '/terms')}>{t.footer.terms}</a>
        <a href={langPath(lang, '/privacy')}>{t.footer.privacy}</a>
        <a href={langPath(lang, '/cookies')}>{t.footer.cookies}</a>
      </div>
    </div>
    <div class="foot-bottom">
      <span>{t.footer.copyright}</span>
      <NewsletterSignup variant="footer" />
      <span>
        <a href={langPath(lang, '/terms')}>{t.footer.terms}</a>
        <a href={langPath(lang, '/privacy')}>{t.footer.privacy}</a>
        <a href={langPath(lang, '/cookies')}>{t.footer.cookies}</a>
      </span>
    </div>
  </div>
</footer>

<script>
  const nav = document.getElementById('nav')!;
  const ham = document.getElementById('ham')!;
  const mob = document.getElementById('mobile-menu')!;
  addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 8), { passive: true });
  ham.addEventListener('click', () => {
    const open = nav.classList.toggle('menu-open');
    ham.setAttribute('aria-expanded', String(open));
    mob.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
  });
</script>
</body>
</html>
