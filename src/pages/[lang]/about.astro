---
import BaseLayout from '@layouts/BaseLayout.astro';
import { LANGS, canonical as makeCanonical, resolveLang } from '@i18n/config';
import { useTranslations } from '@i18n/translations';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
const p = t.about;
const pageCanonical = makeCanonical(lang, '/about');
---
<BaseLayout title="About — Virtus Operandi" description={p.lede} canonical={pageCanonical} lang={lang}>
  <style slot="head">
  .principles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin: 24px 0 8px; }
  @media (max-width: 760px) { .principles { grid-template-columns: 1fr; } }
  .principle { padding: 24px 22px; background: var(--paper-2); border: 1px solid var(--border); border-radius: 14px; display: flex; flex-direction: column; gap: 8px; }
  .principle .n { font-family: var(--mono); font-size: 11px; letter-spacing: 0.10em; color: var(--blue); font-weight: 600; }
  .principle h3 { font-size: 18px; }
  .principle p { font-size: 14.5px; color: var(--muted); margin: 0; }
  </style>

  <span slot="meta-label" class="meta-left"><span class="meta-dot" aria-hidden="true"></span>{p.metaLabel}</span>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow"><span class="live" aria-hidden="true"></span>{p.eyebrow}</span>
      <h1>{p.h1}</h1>
      <p class="lede">{p.lede}</p>
    </div>
  </section>

  <main id="main">
    <div class="container">
      <section>
        <h2>{p.h2meaning}</h2>
        <p set:html={p.p1}></p>
        <p>{p.p2}</p>
      </section>
      <section>
        <h2>{p.h2how}</h2>
        <div class="principles">
          <div class="principle"><span class="n">01 / Method</span><h3>{p.m1title}</h3><p>{p.m1}</p></div>
          <div class="principle"><span class="n">02 / Method</span><h3>{p.m2title}</h3><p>{p.m2}</p></div>
          <div class="principle"><span class="n">03 / Method</span><h3>{p.m3title}</h3><p>{p.m3}</p></div>
        </div>
      </section>
      <section>
        <h2>{p.h2cat}</h2>
        <p>{p.catIntro}</p>
        <ul>
          <li><strong>Virtus Lever</strong> — AI assistant for email triage and drafting</li>
          <li><strong>Virtus Fleet</strong> — ERP built for transport and logistics operators</li>
          <li><strong>Virtus AI Factory</strong> — AI co-pilot for MES/MOM</li>
          <li><strong>Virtus Agents</strong> — Low-code AI agent &amp; automation builder</li>
          <li><strong>Virtus GED</strong> — Electronic document management</li>
          <li><strong>Virtus ERP</strong> — General-purpose ERP for SMB and mid-market</li>
        </ul>
        <p><a href={`/${lang}/#products`}>Browse the full catalogue →</a></p>
      </section>
      <section>
        <h2>{p.h2where}</h2>
        <p>{p.whereP1}</p>
        <p>{p.whereP2} <a href={`/${lang}/contact`}>{p.talkToUs}</a></p>
      </section>
      <p class="note">{p.note}</p>
    </div>
  </main>
</BaseLayout>
