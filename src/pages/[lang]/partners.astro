---
import BaseLayout from '@layouts/BaseLayout.astro';
import { LANGS, canonical as makeCanonical, resolveLang } from '@i18n/config';
import { useTranslations } from '@i18n/translations';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
const p = t.partners;
const pageCanonical = makeCanonical(lang, '/partners');
---
<BaseLayout title="Partners — Virtus Operandi" description={p.lede} canonical={pageCanonical} lang={lang}>
  <style slot="head">
  .btn-pill { display: inline-flex; align-items: center; gap: 8px; padding: 15px 28px; background: var(--blue); color: #fff; font-weight: 600; font-size: 15.5px; border-radius: 999px; transition: background .2s, transform .2s; text-decoration: none; }
  .btn-pill:hover { background: var(--blue-hover); transform: translateY(-2px); }
  </style>
  <span slot="meta-label" class="meta-left"><span class="meta-dot" aria-hidden="true"></span>{p.metaLabel}</span>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow"><span class="live" aria-hidden="true"></span>{p.eyebrow}</span>
      <h1>{p.h1}</h1>
      <p class="lede">{p.lede}</p>
    </div>
  </section>

  <main id="main">
    <div class="container">
      <section>
        <h2>{p.h2tech}</h2>
        <p>{p.techIntro}</p>
        <ul>
          <li><strong>MES / MOM</strong> — Dassault Systèmes Delmia Apriso, Siemens Opcenter.</li>
          <li><strong>ERP</strong> — SAP, Microsoft Dynamics, Salesforce.</li>
          <li><strong>Productivity</strong> — Microsoft 365, Google Workspace, Slack.</li>
          <li><strong>Telematics</strong> — major providers via our Fleet integration layer.</li>
        </ul>
      </section>
      <section>
        <h2>{p.h2si}</h2>
        <p>{p.siP}</p>
        <p><a class="btn-pill" href={`/${lang}/contact`}>{p.becomePartner}</a></p>
      </section>
      <p class="note">{p.note}</p>
    </div>
  </main>
</BaseLayout>
