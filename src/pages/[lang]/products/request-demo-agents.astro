---
import BaseLayout from '@layouts/BaseLayout.astro';
import RequestDemoForm from '@components/RequestDemoForm.astro';
import { LANGS, canonical as makeCanonical, resolveLang } from '@i18n/config';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang    = resolveLang(Astro.params.lang);
const pagePath = '/products/request-demo-agents';
const pageCanonical = makeCanonical(lang, pagePath);

// CF7 form ID from WordPress shortcode:
// [contact-form-7 id="ef796b7" title="Demo Request - Agents"]
const FORM_ID = 'ef796b7';

const meta = {
  fr: {
    title: 'Demander une démo — Virtus Agents · Virtus Operandi',
    description: "Demandez une démonstration de Virtus Agents, le constructeur d'agents IA low-code pour vos opérations.",
    badge: 'AI · Platform',
    h1: 'Demander une démo — Virtus Agents',
    lede: '15 minutes avec un vrai ingénieur. Nous vous montrerons comment construire votre premier agent IA sur vos systèmes réels.',
    card1h: 'Ce que vous obtenez',
    items: ['Démo sur un cas d\'usage de votre opération', 'Réponse sous 1 jour ouvré', 'Appel de 15 min — pas de pitch commercial', 'Ingénieur dédié à votre compte'],
    card2h: 'À propos de Virtus Agents',
    card2p: 'Canvas low-code pour construire des agents qui lisent, décident et agissent sur vos systèmes réels. Human-in-the-loop par défaut.',
  },
  en: {
    title: 'Request a Demo — Virtus Agents · Virtus Operandi',
    description: 'Request a demo of Virtus Agents, the low-code AI agent builder for real operations.',
    badge: 'AI · Platform',
    h1: 'Request a Demo — Virtus Agents',
    lede: '15 minutes with a real engineer. We\'ll show you how to build your first AI agent on your real systems.',
    card1h: 'What you get',
    items: ['Demo on a use case from your operation', 'Reply within 1 business day', '15-min call — no sales pitch', 'Dedicated engineer on your account'],
    card2h: 'About Virtus Agents',
    card2p: 'Low-code canvas to build agents that read, decide, and act on real systems. Human-in-the-loop by default, autonomous when trusted.',
  },
  ar: {
    title: 'طلب عرض توضيحي — Virtus Agents · Virtus Operandi',
    description: 'اطلب عرضاً توضيحياً لـ Virtus Agents، منصة بناء وكلاء الذكاء الاصطناعي.',
    badge: 'AI · Platform',
    h1: 'طلب عرض توضيحي — Virtus Agents',
    lede: '15 دقيقة مع مهندس حقيقي. سنريك كيف تبني أول وكيل ذكاء اصطناعي على أنظمتك الفعلية.',
    card1h: 'ما ستحصل عليه',
    items: ['عرض على حالة استخدام من عمليتك', 'ردّ خلال يوم عمل واحد', 'مكالمة 15 دقيقة — بدون عروض بيع', 'مهندس مخصّص لحسابك'],
    card2h: 'عن Virtus Agents',
    card2p: 'بيئة low-code لبناء وكلاء يقرؤون ويقررون ويتصرفون على أنظمتك الفعلية. مشاركة بشرية بشكل افتراضي.',
  },
} as const;

const m = meta[lang];
---
<BaseLayout
  title={m.title}
  description={m.description}
  canonical={pageCanonical}
  lang={lang}
  langUrls={{
    fr: makeCanonical('fr', pagePath),
    en: makeCanonical('en', pagePath),
    ar: makeCanonical('ar', pagePath),
  }}
>
  <style slot="head">
  .demo-hero-badge {
    display: inline-block; font-family: var(--mono); font-size: 11px;
    padding: 4px 10px; border-radius: 999px; background: var(--paper-2);
    border: 1px solid var(--border); color: #8B5CF6; letter-spacing: 0.10em;
    text-transform: uppercase; font-weight: 600; margin-bottom: 14px;
  }
  .demo-grid {
    display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(40px, 5vw, 64px); align-items: start; margin-top: 40px;
  }
  @media (max-width: 860px) { .demo-grid { grid-template-columns: 1fr; } }
  .demo-sidebar { position: sticky; top: calc(var(--nav-h) + 24px); display: flex; flex-direction: column; gap: 20px; }
  .demo-card { padding: 24px 26px; background: var(--paper-2); border: 1px solid var(--border); border-radius: 16px; }
  .demo-card h3 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; font-weight: 600; }
  .demo-card p { font-size: 14.5px; color: var(--muted); margin: 0; line-height: 1.6; }
  .demo-card ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .demo-card ul li { font-size: 14.5px; color: var(--ink); padding-left: 16px; position: relative; }
  .demo-card ul li::before { content: '→'; position: absolute; left: 0; color: var(--blue); font-size: 12px; }
  </style>

  <span slot="meta-label" class="meta-left">
    <span class="meta-dot" aria-hidden="true"></span>Catalogue · Demo Request
  </span>

  <section class="page-hero">
    <div class="container">
      <span class="demo-hero-badge">{m.badge}</span>
      <h1>{m.h1}</h1>
      <p class="lede">{m.lede}</p>
    </div>
  </section>

  <main id="main">
    <div class="container">
      <div class="demo-grid">
        <div>
          <RequestDemoForm product="Virtus Agents" formId={FORM_ID} lang={lang} />
        </div>
        <aside class="demo-sidebar">
          <div class="demo-card">
            <h3>{m.card1h}</h3>
            <ul>
              {m.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="demo-card">
            <h3>{m.card2h}</h3>
            <p>{m.card2p}</p>
          </div>
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
