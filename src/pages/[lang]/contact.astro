---
import BaseLayout from '@layouts/BaseLayout.astro';
import { LANGS, canonical as makeCanonical, resolveLang } from '@i18n/config';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = resolveLang(Astro.params.lang);
const pageCanonical = makeCanonical(lang, '/contact');
---
<BaseLayout title="Contact — Virtus Operandi" description="Talk to Virtus Operandi. 15-minute calls, real engineers on the line." canonical={pageCanonical} lang={lang}>
  <style slot="head">
  .contact-grid { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr); gap: clamp(40px, 5vw, 64px); max-width: var(--max); margin: 0 auto; }
  @media (max-width: 880px) { .contact-grid { grid-template-columns: 1fr; gap: 40px; } }
  .contact-form { display: flex; flex-direction: column; gap: 18px; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  .field label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--muted); font-weight: 600; }
  .field input, .field textarea, .field select { font: inherit; font-size: 16px; padding: 12px 0; border: 0; border-bottom: 1.5px solid var(--border); background: transparent; color: var(--ink); transition: border-color .2s ease; }
  .field input:focus, .field textarea:focus, .field select:focus { outline: none; border-bottom-color: var(--blue); }
  .field textarea { min-height: 100px; resize: vertical; }
  .contact-form .actions { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-top: 8px; }
  .contact-form .actions small { font-family: var(--mono); font-size: 11px; color: var(--muted); letter-spacing: 0.04em; }
  .contact-side { display: flex; flex-direction: column; gap: 28px; }
  .contact-card { padding: 24px 26px; background: var(--paper-2); border: 1px solid var(--border); border-radius: 16px; }
  .contact-card h3 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; font-weight: 600; }
  .contact-card a.line { display: flex; align-items: baseline; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed var(--border); font-size: 15px; color: var(--ink); }
  .contact-card a.line:last-of-type { border-bottom: 0; }
  .contact-card a.line span { font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .contact-card a.line:hover { color: var(--blue); border-bottom-color: var(--blue); }
  .contact-card.dark { background: var(--ink); color: #fff; border-color: var(--ink); }
  .contact-card.dark h3 { color: rgba(255,255,255,0.55); }
  .contact-card.dark p { color: rgba(255,255,255,0.78); font-size: 14.5px; line-height: 1.6; }
  .contact-card.dark .btn-pill { background: #fff; color: var(--ink); box-shadow: none; margin-top: 14px; }
  .contact-card.dark .btn-pill:hover { background: var(--blue); color: #fff; }
  .btn-pill { display: inline-flex; align-items: center; gap: 8px; padding: 15px 28px; background: var(--blue); color: #fff; font-weight: 600; font-size: 15.5px; border-radius: 999px; transition: background .2s, transform .2s; text-decoration: none; }
  .btn-pill:hover { background: var(--blue-hover); transform: translateY(-2px); }
  </style>

  <span slot="meta-label" class="meta-left"><span class="meta-dot" aria-hidden="true"></span>Contact · sales open</span>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow"><span class="live" aria-hidden="true"></span>Talk to us</span>
      <h1>Fifteen minutes. A real engineer.</h1>
      <p class="lede">Tell us what your operation looks like and what's slowing it down. We'll walk you through exactly which products fit — and which don't.</p>
    </div>
  </section>

  <main id="main">
    <div class="contact-grid">
      <form class="contact-form" id="contact-form" onsubmit="event.preventDefault(); alert('Form submission is not wired up yet — this is a preview.');">
        <div class="field"><label for="name">Your name</label><input type="text" id="name" name="name" required autocomplete="name" /></div>
        <div class="field"><label for="company">Company</label><input type="text" id="company" name="company" autocomplete="organization" /></div>
        <div class="field"><label for="email">Work email</label><input type="email" id="email" name="email" required autocomplete="email" /></div>
        <div class="field">
          <label for="product">Which product are you curious about?</label>
          <select id="product" name="product">
            <option value="">No preference yet</option>
            <option value="lever">Virtus Lever — AI email</option>
            <option value="fleet">Virtus Fleet — Transport ERP</option>
            <option value="ai-factory">Virtus AI Factory — MES/MOM AI</option>
            <option value="agents">Virtus Agents — AI agent platform</option>
            <option value="ged">Virtus GED — Document management</option>
            <option value="erp">Virtus ERP — General ERP</option>
            <option value="all">The full catalogue</option>
          </select>
        </div>
        <div class="field"><label for="message">What's the problem you're trying to solve?</label><textarea id="message" name="message" rows="4"></textarea></div>
        <div class="actions">
          <button class="btn-pill" type="submit">Send →</button>
          <small>We reply within 1 business day.</small>
        </div>
        <p class="note" style="margin-top: 12px;">Preview state — form submission is not wired to a backend yet.</p>
      </form>
      <aside class="contact-side">
        <div class="contact-card dark">
          <h3>Book a 15-minute call</h3>
          <p>Pick a slot directly. We'll send a Google Meet link and a short prep questionnaire so the call doesn't start at zero.</p>
          <a class="btn-pill" href="#" aria-disabled="true">Open calendar →</a>
        </div>
        <div class="contact-card">
          <h3>Direct email</h3>
          <a class="line" href="mailto:sales@virtusoperandi.com">sales@virtusoperandi.com<span>Sales</span></a>
          <a class="line" href="mailto:support@virtusoperandi.com">support@virtusoperandi.com<span>Support</span></a>
          <a class="line" href="mailto:careers@virtusoperandi.com">careers@virtusoperandi.com<span>Careers</span></a>
          <a class="line" href="mailto:security@virtusoperandi.com">security@virtusoperandi.com<span>Security</span></a>
        </div>
        <div class="contact-card">
          <h3>Where we are</h3>
          <p style="margin-bottom: 8px;"><strong>Virtus Operandi SARL</strong></p>
          <p style="font-size: 14.5px; color: var(--muted);">[Office address — to be confirmed]<br>Casablanca, Morocco</p>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>
