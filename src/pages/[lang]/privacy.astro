---
import BaseLayout from '@layouts/BaseLayout.astro';
import { LANGS, canonical as makeCanonical, resolveLang } from '@i18n/config';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = resolveLang(Astro.params.lang);
const pageCanonical = makeCanonical(lang, '/privacy');
---
<BaseLayout title="Privacy Policy — Virtus Operandi" description="How Virtus Operandi collects, uses, and protects personal data." canonical={pageCanonical} lang={lang}>
  <style slot="head">
  .toc { background: var(--paper-2); border: 1px solid var(--border); border-radius: 12px; padding: 20px 24px; margin-bottom: 32px; }
  .toc h4 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
  .toc ol { margin: 0; padding-left: 20px; }
  .toc li { font-size: 14px; color: var(--muted); margin-bottom: 4px; }
  .toc a { color: var(--blue); }
  </style>
  <span slot="meta-label" class="meta-left"><span class="meta-dot" aria-hidden="true"></span>Legal · last updated 2026-06-08</span>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow"><span class="live" aria-hidden="true"></span>Legal</span>
      <h1>Privacy Policy.</h1>
      <p class="lede">How we collect, use, and protect personal data. Last reviewed 2026-06-08.</p>
    </div>
  </section>

  <main id="main">
    <div class="container">
      <div class="toc">
        <h4>On this page</h4>
        <ol>
          <li><a href="#scope">Who this applies to</a></li>
          <li><a href="#collect">What we collect</a></li>
          <li><a href="#use">How we use it</a></li>
          <li><a href="#legal">Legal bases</a></li>
          <li><a href="#share">Who we share it with</a></li>
          <li><a href="#retention">How long we keep it</a></li>
          <li><a href="#rights">Your rights</a></li>
          <li><a href="#transfers">International transfers</a></li>
          <li><a href="#cookies">Cookies</a></li>
          <li><a href="#security">Security</a></li>
          <li><a href="#changes">Changes</a></li>
          <li><a href="#contact">Contact us</a></li>
        </ol>
      </div>
      <section id="scope"><h2>1. Who this applies to</h2><p>This Privacy Policy applies to personal data Virtus Operandi processes when you visit virtusoperandi.com, contact us, or use any product in the Virtus Operandi catalogue.</p></section>
      <section id="collect"><h2>2. What we collect</h2><ul><li><strong>Contact data</strong> — name, email, company, role.</li><li><strong>Account data</strong> — login credentials, account settings.</li><li><strong>Usage data</strong> — pages visited, features used, timestamps, IP address.</li><li><strong>Customer data</strong> — content you submit to our products. We process this on your behalf as a processor.</li><li><strong>Cookies &amp; similar</strong> — see our <a href={`/${lang}/cookies`}>Cookie Policy</a>.</li></ul></section>
      <section id="use"><h2>3. How we use it</h2><p>We use personal data to provide, maintain, and improve the Service; respond to questions; send service announcements; detect security incidents; and comply with legal obligations.</p></section>
      <section id="legal"><h2>4. Legal bases (GDPR)</h2><ul><li><strong>Contract</strong> — to provide the Service;</li><li><strong>Legitimate interests</strong> — to operate, secure, and improve the Service;</li><li><strong>Consent</strong> — for non-essential cookies and marketing emails;</li><li><strong>Legal obligation</strong> — to comply with applicable law.</li></ul></section>
      <section id="share"><h2>5. Who we share it with</h2><p>We share personal data only with sub-processors we use to run the Service, authorities when required by law, and acquirers in the event of a merger or acquisition. We do not sell personal data.</p></section>
      <section id="retention"><h2>6. How long we keep it</h2><p>We retain personal data only as long as needed for the purpose collected. Account data is deleted within ninety (90) days of account closure unless retention is required by law.</p></section>
      <section id="rights"><h2>7. Your rights</h2><p>You may have the right to access, correct, delete, restrict, or port your personal data, and to withdraw consent. To exercise these rights, contact <a href="mailto:privacy@virtusoperandi.com">privacy@virtusoperandi.com</a>.</p></section>
      <section id="transfers"><h2>8. International transfers</h2><p>Personal data may be processed in Morocco and other countries where our sub-processors operate. Where data is transferred outside the EEA/UK, we rely on Standard Contractual Clauses.</p></section>
      <section id="cookies"><h2>9. Cookies</h2><p>See our <a href={`/${lang}/cookies`}>Cookie Policy</a> for details.</p></section>
      <section id="security"><h2>10. Security</h2><p>We implement administrative, technical, and physical safeguards. See <a href={`/${lang}/security`}>Security</a> for more.</p></section>
      <section id="changes"><h2>11. Changes</h2><p>Material changes will be communicated via the Service or by email at least thirty (30) days before they take effect.</p></section>
      <section id="contact"><h2>12. Contact us</h2><p>Data Protection contact: <a href="mailto:privacy@virtusoperandi.com">privacy@virtusoperandi.com</a></p><p><strong>Virtus Operandi SARL</strong><br>Casablanca, Morocco</p></section>
      <p class="note">Draft. This Privacy Policy has not yet been reviewed by legal counsel — pending review before public production launch.</p>
    </div>
  </main>
</BaseLayout>
