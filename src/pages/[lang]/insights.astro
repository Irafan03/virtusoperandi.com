---
import BaseLayout from '@layouts/BaseLayout.astro';
import { LANGS, canonical as makeCanonical, resolveLang } from '@i18n/config';
import { useTranslations } from '@i18n/translations';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = resolveLang(Astro.params.lang);
const t = useTranslations(lang);
const p = t.insights;
const pageCanonical = makeCanonical(lang, '/insights');
---
<BaseLayout title="Insights — Virtus Operandi" description={p.lede} canonical={pageCanonical} lang={lang}>
  <span slot="meta-label" class="meta-left"><span class="meta-dot" aria-hidden="true"></span>{p.metaLabel}</span>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow"><span class="live" aria-hidden="true"></span>{p.eyebrow}</span>
      <h1>{p.h1}</h1>
      <p class="lede">{p.lede}</p>
    </div>
  </section>

  <main id="main">
    <div class="container">
      <section>
        <h2>{p.h2soon}</h2>
        <p>{p.soonP}</p>
        <ul>
          <li set:html={p.cat1}></li>
          <li set:html={p.cat2}></li>
          <li set:html={p.cat3}></li>
        </ul>
      </section>
      <section>
        <h2>{p.h2case}</h2>
        <p>{p.caseP} <a href={`/${lang}/contact`}>{p.talkToUs}</a></p>
      </section>
      <p class="note">{p.note}</p>
    </div>
  </main>
</BaseLayout>
