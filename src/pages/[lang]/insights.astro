---
import BaseLayout from '@layouts/BaseLayout.astro';
import { LANGS, canonical as makeCanonical, resolveLang } from '@i18n/config';

export async function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = resolveLang(Astro.params.lang);
const pageCanonical = makeCanonical(lang, '/insights');
---
<BaseLayout title="Insights — Virtus Operandi" description="Notes, write-ups, and case studies from the team." canonical={pageCanonical} lang={lang}>
  <span slot="meta-label" class="meta-left"><span class="meta-dot" aria-hidden="true"></span>Insights · launching Q3</span>

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow"><span class="live" aria-hidden="true"></span>Insights · launching Q3</span>
      <h1>From the operating room.</h1>
      <p class="lede">Field notes, engineering write-ups, and customer stories. Currently a placeholder — first articles drop with the launch cohort in Q3 2026.</p>
    </div>
  </section>

  <main id="main">
    <div class="container">
      <section>
        <h2>Coming soon.</h2>
        <p>We're holding off on insights content until the first launch-partner pilots ship. When they do, the page fills with three categories of post:</p>
        <ul>
          <li><strong>Field notes</strong> — what we saw on the floor, in the dispatch room, or at the back-office.</li>
          <li><strong>Engineering write-ups</strong> — deeper technical pieces about how the catalogue is built.</li>
          <li><strong>Case studies</strong> — what a launch partner shipped, what it cost, what they got back.</li>
        </ul>
      </section>
      <section>
        <h2>Want to be in the first case study?</h2>
        <p>We're working with the first ten organisations to roll the catalogue out. <a href={`/${lang}/contact`}>Talk to us.</a></p>
      </section>
      <p class="note">Page reserved. Case studies index follows the same launch schedule.</p>
    </div>
  </main>
</BaseLayout>
