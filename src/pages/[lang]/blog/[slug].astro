---
import BlogLayout from '@layouts/BlogLayout.astro';
import { LANGS, langPath, canonical as makeCanonical, resolveLang } from '@i18n/config';
import { useTranslations } from '@i18n/translations';
import { getPostsByLang, coverUrl, primaryTag, authorName, formatDate } from '@lib/wordpress';
import type { WpPost } from '@lib/wordpress';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of LANGS) {
    const posts = await getPostsByLang(lang);
    for (let i = 0; i < posts.length; i++) {
      const slug = decodeURIComponent(posts[i].slug);
      paths.push({
        params: { lang, slug },
        props:  { post: posts[i], prev: posts[i + 1] ?? null, next: posts[i - 1] ?? null },
      });
    }
  }
  return paths;
}

interface Props { post: WpPost; prev: WpPost | null; next: WpPost | null }
const { post, prev, next } = Astro.props;
const lang = resolveLang(Astro.params.lang);
const t    = useTranslations(lang);

const pageCanonical = makeCanonical(lang, `/blog/${decodeURIComponent(post.slug)}`);
const hasFeatured   = !!post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
const cover         = coverUrl(post);
const coverAlt      = post._embedded?.['wp:featuredmedia']?.[0]?.alt_text ?? post.title.rendered;
const bodyHtml      = hasFeatured
  ? post.content.rendered
  : post.content.rendered.replace(/<img[^>]+>/, '');
const tag           = primaryTag(post);
const dateIso       = post.date.slice(0, 10);

const jsonLd = {
  '@context':    'https://schema.org',
  '@type':       'BlogPosting',
  headline:      post.title.rendered,
  description:   post.excerpt.rendered.replace(/<[^>]*>/g, '').trim(),
  datePublished: dateIso,
  url:           pageCanonical,
  publisher:     { '@type': 'Organization', name: 'Virtus Operandi', url: 'https://virtusoperandi.com' },
  ...(cover ? { image: cover } : {}),
};
---

<BlogLayout
  title={`${post.title.rendered} · Virtus Operandi Blog`}
  description={post.excerpt.rendered.replace(/<[^>]*>/g, '').trim()}
  canonical={pageCanonical}
  lang={lang}
  og={{ title: post.title.rendered, description: post.excerpt.rendered.replace(/<[^>]*>/g, '').trim(), image: cover }}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <style>
      .post-container { max-width: 740px; margin: 0 auto; padding: 0 var(--gutter); }
      .post-header { padding: clamp(40px,6vw,72px) var(--gutter) clamp(24px,4vw,40px); background: radial-gradient(60% 50% at 85% 35%, rgba(0,102,255,0.05), transparent 70%), var(--paper); border-bottom: 1px solid var(--border); }
      .post-header__inner { max-width: 740px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; }
      .post-tag { display: inline-flex; width: max-content; padding: 4px 12px; border-radius: 999px; background: rgba(0,102,255,0.08); color: var(--blue); font-family: var(--mono); font-size: 11px; letter-spacing: 0.10em; text-transform: uppercase; font-weight: 600; }
      .post-title { font-size: clamp(28px,4vw,42px); font-weight: 700; line-height: 1.15; letter-spacing: -1.2px; color: var(--ink); margin: 0; }
      .post-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.06em; color: var(--muted); }
      .post-meta .sep { opacity: 0.4; }
      .post-cover { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; border-radius: 12px; margin: clamp(28px,4vw,40px) 0; }
      .post-cover-placeholder { width: 100%; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; border-radius: 12px; margin: clamp(28px,4vw,40px) 0; background: var(--paper-2); font-family: var(--mono); font-size: 12px; letter-spacing: 0.08em; color: var(--muted); }
      .post-body { font-size: 17px; line-height: 1.75; color: var(--text); }
      .post-body p { margin-bottom: 20px; }
      .post-body p:last-child { margin-bottom: 0; }
      .post-body h2 { font-size: clamp(22px,2.4vw,26px); font-weight: 700; letter-spacing: -0.6px; margin: 40px 0 14px; color: var(--ink); }
      .post-body h3 { font-size: 19px; font-weight: 600; letter-spacing: -0.3px; margin: 28px 0 10px; color: var(--ink); }
      .post-body ul, .post-body ol { padding-left: 24px; margin-bottom: 20px; }
      .post-body li { margin-bottom: 8px; }
      .post-body a { color: var(--blue); border-bottom: 1px solid rgba(0,102,255,0.3); transition: border-color .15s ease; }
      .post-body a:hover { border-bottom-color: var(--blue); }
      .post-body strong { color: var(--ink); font-weight: 600; }
      .post-body blockquote { margin: 28px 0; padding: 18px 24px; border-left: 3px solid var(--blue); background: rgba(0,102,255,0.04); border-radius: 0 8px 8px 0; font-size: 16px; color: var(--ink); }
      .post-body blockquote p { margin-bottom: 0; }
      .post-body code { font-family: var(--mono); font-size: 13.5px; background: var(--paper-2); border: 1px solid var(--border); padding: 2px 6px; border-radius: 5px; }
      .post-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: clamp(40px,5vw,64px); padding-top: 32px; border-top: 1px solid var(--border); }
      @media (max-width: 560px) { .post-nav { grid-template-columns: 1fr; } }
      .post-nav__link { display: flex; flex-direction: column; gap: 5px; padding: 18px 20px; border: 1.5px solid var(--border); border-radius: 12px; text-decoration: none; color: inherit; transition: border-color .2s ease, transform .2s ease; }
      .post-nav__link:hover { border-color: var(--blue); transform: translateY(-2px); }
      .post-nav__link--next { text-align: right; }
      .post-nav__link--empty { visibility: hidden; }
      .post-nav__label { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--muted); font-weight: 600; }
      .post-nav__title { font-size: 14.5px; font-weight: 600; color: var(--ink); line-height: 1.35; }
      .back-btn { display: inline-flex; align-items: center; gap: 8px; margin-top: 28px; padding: 10px 18px; border: 1.5px solid var(--border); border-radius: 999px; font-size: 13.5px; font-weight: 600; color: var(--muted); text-decoration: none; transition: border-color .15s ease, color .15s ease; }
      .back-btn:hover { border-color: var(--ink); color: var(--ink); }
    </style>
  </Fragment>

  <main id="main">
    <article itemscope itemtype="https://schema.org/BlogPosting">

      <header class="post-header">
        <div class="post-header__inner">
          {tag && <span class="post-tag" itemprop="articleSection">{tag}</span>}
          <h1 class="post-title" itemprop="headline" set:html={post.title.rendered} />
          <div class="post-meta">
            <time datetime={dateIso} itemprop="datePublished">{formatDate(post.date)}</time>
            {authorName(post) && (
              <>
                <span class="sep" aria-hidden="true">·</span>
                <span itemprop="author" itemscope itemtype="https://schema.org/Person">
                  <span itemprop="name">{authorName(post)}</span>
                </span>
              </>
            )}
          </div>
        </div>
      </header>

      <div class="post-container">
        {cover
          ? <img class="post-cover" src={cover} alt={coverAlt} width="740" height="416" />
          : <div class="post-cover-placeholder" role="img" aria-label="Cover image placeholder">cover image · 16:9</div>
        }

        <div class="post-body entry-content" itemprop="articleBody" set:html={bodyHtml} />

        <nav class="post-nav" aria-label="Article navigation">
          {prev
            ? <a class="post-nav__link post-nav__link--prev" href={langPath(lang, `/blog/${decodeURIComponent(prev.slug)}`)}>
                <span class="post-nav__label">{t.blog.prev}</span>
                <span class="post-nav__title" set:html={prev.title.rendered} />
              </a>
            : <span class="post-nav__link post-nav__link--empty" aria-hidden="true"></span>
          }
          {next
            ? <a class="post-nav__link post-nav__link--next" href={langPath(lang, `/blog/${decodeURIComponent(next.slug)}`)}>
                <span class="post-nav__label">{t.blog.next}</span>
                <span class="post-nav__title" set:html={next.title.rendered} />
              </a>
            : <span class="post-nav__link post-nav__link--empty" aria-hidden="true"></span>
          }
        </nav>

        <a class="back-btn" href={langPath(lang, '/blog')}>{t.blog.back}</a>
      </div>
    </article>
  </main>
</BlogLayout>
