---
import BlogLayout   from '@layouts/BlogLayout.astro';
import { getAllPosts, coverUrl, primaryTag, categorySlug, authorName, formatDate, stripHtml } from '@lib/wordpress';

const posts      = await getAllPosts();
const allSlugs   = ['all', ...Array.from(new Set(posts.map(categorySlug).filter(Boolean)))];
const canonical  = 'https://virtusoperandi.com/blog';
---

<BlogLayout
  title="Blog — Virtus Operandi"
  description="Field notes, engineering write-ups, and operator stories from the Virtus Operandi team."
  canonical={canonical}
>
  <section class="page-hero" aria-label="Page introduction">
    <div class="container">
      <span class="eyebrow"><span class="live" aria-hidden="true"></span>Blog · field notes &amp; write-ups</span>
      <h1>From the operating room.</h1>
      <p class="lede">What we see on factory floors, in dispatch rooms, and at the back-office. Written by the engineers who were there.</p>
    </div>
  </section>

  <main id="main">
    <div class="container" style="max-width: var(--max);">

      <nav aria-label="Filter by category" class="blog-filters">
        {allSlugs.map(slug => (
          <button
            class="filter-btn"
            aria-pressed={slug === 'all' ? 'true' : 'false'}
            data-filter={slug}
          >{slug === 'all' ? 'All' : slug}</button>
        ))}
      </nav>

      <ul class="post-grid" role="list">
        {posts.map(post => {
          const tag   = primaryTag(post);
          const slug  = categorySlug(post);
          const cover = coverUrl(post);
          const author = authorName(post);
          const alt   = post._embedded?.['wp:featuredmedia']?.[0]?.alt_text ?? post.title.rendered;
          return (
            <li data-tag={slug} itemscope itemtype="https://schema.org/BlogPosting">
              <a href={`/blog/${post.slug}`} class="post-card" aria-label={`Read: ${post.title.rendered}`}>
                {cover
                  ? <img class="post-card__cover" src={cover} alt={alt} width="640" height="360" loading="lazy" />
                  : <div class="post-card__cover-placeholder" aria-hidden="true">cover · 16:9</div>
                }
                <div class="post-card__body">
                  {tag && <span class="post-card__tag" itemprop="articleSection">{tag}</span>}
                  <h2 class="post-card__title" itemprop="headline" set:html={post.title.rendered} />
                  <p class="post-card__excerpt" itemprop="description">{stripHtml(post.excerpt.rendered)}</p>
                  <footer class="post-card__meta">
                    <time datetime={post.date} itemprop="datePublished">{formatDate(post.date)}</time>
                    {author && (
                      <>
                        <span class="sep" aria-hidden="true">·</span>
                        <span itemprop="author" itemscope itemtype="https://schema.org/Person">
                          <span itemprop="name">{author}</span>
                        </span>
                      </>
                    )}
                  </footer>
                </div>
              </a>
            </li>
          );
        })}
      </ul>

      <nav class="blog-pagination" aria-label="Blog pagination">
        <a class="page-btn" href="/blog" aria-current="page">1</a>
      </nav>

    </div>
  </main>
</BlogLayout>

<style>
  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 36px;
  }
  .filter-btn {
    padding: 6px 16px;
    border: 1.5px solid var(--border);
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--muted);
    background: transparent;
    cursor: pointer;
    transition: border-color .15s ease, color .15s ease, background .15s ease;
  }
  .filter-btn:hover,
  .filter-btn[aria-pressed="true"] {
    border-color: var(--blue);
    color: var(--blue);
    background: rgba(0,102,255,0.06);
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
    list-style: none;
    padding: 0;
  }
  @media (max-width: 900px) { .post-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 580px) { .post-grid { grid-template-columns: 1fr; } }
  .post-grid > li { display: flex; }
  .post-grid > li[hidden] { display: none; }
  :global(.post-card) {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color .2s ease, transform .2s ease;
    text-decoration: none;
    color: inherit;
  }
  :global(.post-card:hover) { border-color: var(--blue); transform: translateY(-3px); }
  :global(.post-card__cover) { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; }
  :global(.post-card__cover-placeholder) {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--paper-2);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  :global(.post-card__body) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px 22px 22px;
  }
  :global(.post-card__tag) {
    display: inline-flex;
    width: max-content;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(0,102,255,0.08);
    color: var(--blue);
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    font-weight: 600;
  }
  :global(.post-card__title) {
    font-family: var(--display);
    font-size: 17px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
    letter-spacing: -0.3px;
    margin: 0;
  }
  :global(.post-card__excerpt) {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  :global(.post-card__meta) {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--muted);
    padding-top: 12px;
    border-top: 1px solid var(--border-soft);
  }
  .blog-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding-top: 16px;
  }
  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    background: transparent;
    text-decoration: none;
    transition: border-color .15s ease, color .15s ease, background .15s ease;
  }
  .page-btn[aria-current="page"] { border-color: var(--blue); background: var(--blue); color: #fff; }
  .page-btn:hover:not([aria-current="page"]) { border-color: var(--ink); color: var(--ink); }
</style>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      const filter = (btn as HTMLElement).dataset.filter;
      document.querySelectorAll<HTMLElement>('.post-grid > li').forEach(li => {
        li.hidden = filter !== 'all' && li.dataset.tag !== filter;
      });
    });
  });
</script>
