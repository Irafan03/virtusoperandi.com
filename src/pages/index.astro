---
import BlogLayout from '@layouts/BlogLayout.astro';
---

<BlogLayout
  title="Virtus Operandi — Software for Real Operations"
  description="Software that codifies the way real operations get done. Built by operators for operators — across manufacturing, transport, and the back office."
  canonical="https://virtusoperandi.com/"
>
  <main id="main">
    <section class="home-hero">
      <div class="container">
        <h1>Software for real operations.</h1>
        <p class="lede">Built by operators for operators — across manufacturing, transport, and the back office.</p>
        <div class="hero-cta">
          <a href="/contact" class="btn-primary">Book a demo</a>
          <a href="/about" class="btn-secondary">Learn more</a>
        </div>
      </div>
    </section>

    <section id="products" class="section">
      <div class="container">
        <h2>Products</h2>
        <ul class="product-grid" role="list">
          <li><a href="/products/virtus-lever"><strong>Virtus Lever</strong><span>Process automation platform</span></a></li>
          <li><a href="/products/virtus-fleet"><strong>Virtus Fleet</strong><span>Transport &amp; logistics management</span></a></li>
          <li><a href="/products/virtus-ai-factory"><strong>Virtus AI Factory</strong><span>Industrial AI at scale</span></a></li>
          <li><a href="/products/virtus-agents"><strong>Virtus Agents</strong><span>Autonomous operational agents</span></a></li>
          <li><a href="/products/virtus-ged"><strong>Virtus GED</strong><span>Document management system</span></a></li>
          <li><a href="/products/virtus-erp"><strong>Virtus ERP</strong><span>Integrated resource planning</span></a></li>
        </ul>
      </div>
    </section>

    <section id="industries" class="section">
      <div class="container">
        <h2>Industries</h2>
        <ul class="product-grid" role="list">
          <li><a href="/industries/manufacturing"><strong>Manufacturing</strong><span>Factory floor to boardroom</span></a></li>
          <li><a href="/industries/transport-logistics"><strong>Transport &amp; Logistics</strong><span>Fleet, dispatch, last-mile</span></a></li>
          <li><a href="/industries/professional-services"><strong>Professional Services</strong><span>Back-office to client delivery</span></a></li>
          <li><a href="/industries/cross-industry"><strong>Cross-industry</strong><span>Shared platform capabilities</span></a></li>
        </ul>
      </div>
    </section>
  </main>
</BlogLayout>

<style>
  .home-hero {
    padding: 120px 0 80px;
    text-align: center;
  }
  .home-hero h1 {
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 700;
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .home-hero .lede {
    font-size: clamp(16px, 2vw, 20px);
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }
  .hero-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    padding: 14px 32px;
    background: var(--blue);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    font-size: 15px;
    transition: opacity .15s ease;
  }
  .btn-primary:hover { opacity: 0.88; }
  .btn-secondary {
    padding: 14px 32px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    font-size: 15px;
    color: var(--ink);
    transition: border-color .15s ease;
  }
  .btn-secondary:hover { border-color: var(--ink); }
  .section {
    padding: 80px 0;
    border-top: 1px solid var(--border-soft);
  }
  .section h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 36px;
    letter-spacing: -0.5px;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media (max-width: 900px) { .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .product-grid { grid-template-columns: 1fr; } }
  .product-grid a {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: border-color .15s ease, transform .15s ease;
  }
  .product-grid a:hover { border-color: var(--blue); transform: translateY(-2px); }
  .product-grid strong { font-size: 16px; font-weight: 600; color: var(--ink); }
  .product-grid span { font-size: 13px; color: var(--muted); }
</style>
