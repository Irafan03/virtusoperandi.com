---
import BaseLayout from '@layouts/BaseLayout.astro';
import RequestDemoForm from '@components/RequestDemoForm.astro';

// CF7 WordPress numeric post ID (used in REST URL + hidden fields)
const WP_FORM_ID = '254';
---
<BaseLayout
  title="Demander une démo — Virtus Lever · Virtus Operandi"
  description="Demandez une démonstration de Virtus Lever, l'assistant IA qui automatise vos e-mails et libère 3h par jour."
  canonical="https://virtusoperandi.com/products/request-demo-virtus-lever"
>
  <style slot="head">
  .demo-hero-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--paper-2);
    border: 1px solid var(--border);
    color: #0066FF;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 14px;
  }
  .demo-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(40px, 5vw, 64px);
    align-items: start;
    margin-top: 40px;
  }
  @media (max-width: 860px) {
    .demo-grid { grid-template-columns: 1fr; }
  }
  .demo-sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 24px);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .demo-card {
    padding: 24px 26px;
    background: var(--paper-2);
    border: 1px solid var(--border);
    border-radius: 16px;
  }
  .demo-card h3 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .demo-card p { font-size: 14.5px; color: var(--muted); margin: 0; line-height: 1.6; }
  .demo-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .demo-card ul li {
    font-size: 14.5px;
    color: var(--ink);
    padding-left: 16px;
    position: relative;
  }
  .demo-card ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--blue);
    font-size: 12px;
  }
  </style>

  <span slot="meta-label" class="meta-left">
    <span class="meta-dot" aria-hidden="true"></span>Catalogue · Demo Request
  </span>

  <section class="page-hero">
    <div class="container">
      <span class="demo-hero-badge">AI · Productivity</span>
      <h1>Demander une démo — Virtus Lever</h1>
      <p class="lede">15 minutes avec un vrai ingénieur. Nous vous montrerons exactement comment Virtus Lever s'intègre à vos boîtes mail.</p>
    </div>
  </section>

  <main id="main">
    <div class="container">
      <div class="demo-grid">
        <div>
          <RequestDemoForm product="Virtus Lever" wpFormId={WP_FORM_ID} />
        </div>
        <aside class="demo-sidebar">
          <div class="demo-card">
            <h3>Ce que vous obtenez</h3>
            <ul>
              <li>Démo personnalisée sur votre flux e-mail</li>
              <li>Réponse sous 1 jour ouvré</li>
              <li>Appel de 15 min — pas de pitch commercial</li>
              <li>Ingénieur dédié à votre compte</li>
            </ul>
          </div>
          <div class="demo-card">
            <h3>À propos de Virtus Lever</h3>
            <p>Virtus Lever automatise la partie mécanique de l'e-mail — rédaction dans votre ton, triage, extraction de tâches. Connecte Gmail, Microsoft 365 et tout IMAP.</p>
          </div>
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>
